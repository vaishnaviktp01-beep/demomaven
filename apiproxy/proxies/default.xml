<ProxyEndpoint name="default">
<Description>Default proxy endpoint</Description>
<HTTPProxyConnection>
<BasePath>/v1/hello</BasePath>
</HTTPProxyConnection>
<FaultRules>
<FaultRule name="DefaultFaultRule">
<Step>
<Name>AM-ErrorResponse</Name>
</Step>
<Condition>true</Condition>
</FaultRule>
</FaultRules>
<PreFlow name="PreFlow">
<Request>
<Step>
<Name>AM-SetHeaders</Name>
</Step>
</Request>
<Response/>
</PreFlow>
<PostFlow name="PostFlow">
<Request/>
<Response/>
</PostFlow>
<Flows/>
<RouteRule name="default">
<TargetEndpoint>default</TargetEndpoint>
</RouteRule>
</ProxyEndpoint>
