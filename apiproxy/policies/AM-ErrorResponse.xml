<AssignMessage continueOnError="false" enabled="true" name="AM-ErrorResponse">
<DisplayName>AM-ErrorResponse</DisplayName>
<Set>
<Payload contentType="application/json"> {"error": {"code": {response.status.code}, "message": "{error.message}", "requestId": "{messageid}"}} </Payload>
<StatusCode>{response.status.code}</StatusCode>
<ReasonPhrase>{response.reason.phrase}</ReasonPhrase>
</Set>
<IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
<AssignTo createNew="false" transport="http" type="response"/>
</AssignMessage>
