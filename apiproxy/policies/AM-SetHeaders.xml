<AssignMessage continueOnError="false" enabled="true" name="AM-SetHeaders">
<DisplayName>AM-SetHeaders</DisplayName>
<Set>
<Headers>
<Header name="X-API-Version">v1</Header>
<Header name="X-Forwarded-Environment">{environment.name}</Header>
<Header name="X-Request-ID">{messageid}</Header>
</Headers>
</Set>
<Remove>
<Headers>
<Header name="X-Internal-Token"/>
</Headers>
</Remove>
<IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
</AssignMessage>
